{
  "expo": {
    "name": "Buses",
    "slug": "buses",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "buses",
    "icon": "./assets/images/icon.png",
    "android": {
      "backgroundColor": "#000000",
      "package": "com.vandam.buses"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": ["./assets/fonts/PublicSans-Regular.ttf"]
        }
      ],
      "./plugins/withAndroidConfigChanges",
      "./plugins/withAndroidTheme",
      "expo-asset",
      "expo-sqlite",
      "@maplibre/maplibre-react-native"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {}
    }
  }
}
